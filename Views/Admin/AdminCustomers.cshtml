                                    <button class="action-btn" title="View" onclick="openDetail('Neha Rao','#CUST-008','neha.rao@rediffmail.com','+91 93322 11445','14 Apr 2024','1','₹8,500','New','NR','#f59e0b','Audi R8')"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg></button>
                                    <button class="action-btn" title="Email"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg></button>
                                    <button class="action-btn danger" title="Remove" onclick="removeRow(this)"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></svg></button>
                                </div>
                            </td>
                        </tr>

                    </tbody>
                </table>
            </div>
        </div>
    </main>

    <!-- ── CUSTOMER DETAIL MODAL ── -->
    <div class="modal-overlay" id="detailModal" onclick="overlayClose(event)">
        <div class="modal detail-modal">
            <button class="modal-close" onclick="closeDetail()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </button>
            <div class="dm-band" id="dmBand">
                <div class="dm-av-large" id="dmAv"></div>
            </div>
            <div class="dm-body">
                <div class="dm-top">
                    <div>
                        <h2 class="dm-name" id="dmName"></h2>
                        <span class="dm-cid" id="dmId"></span>
                    </div>
                    <span class="status-pill" id="dmStatus"></span>
                </div>
                <div class="dm-info-grid">
                    <div class="dm-info-row">
                        <div class="dm-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg></div>
                        <div><div class="dm-lbl">Email</div><div class="dm-val" id="dmEmail"></div></div>
                    </div>
                    <div class="dm-info-row">
                        <div class="dm-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 21.73 16.92z" /></svg></div>
                        <div><div class="dm-lbl">Phone</div><div class="dm-val" id="dmPhone"></div></div>
                    </div>
                    <div class="dm-info-row">
                        <div class="dm-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg></div>
                        <div><div class="dm-lbl">Member Since</div><div class="dm-val" id="dmJoined"></div></div>
                    </div>
                    <div class="dm-info-row">
                        <div class="dm-ico"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="8" width="22" height="10" rx="2" /><path d="M5 8V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2" /></svg></div>
                        <div><div class="dm-lbl">Vehicles Rented</div><div class="dm-val" id="dmVehicles"></div></div>
                    </div>
                </div>
                <div class="dm-stats">
                    <div class="dm-stat"><div class="dm-stat-num" id="dmBookings"></div><div class="dm-stat-lbl">Bookings</div></div>
                    <div class="dm-sep"></div>
                    <div class="dm-stat"><div class="dm-stat-num gold" id="dmSpent"></div><div class="dm-stat-lbl">Total Spent</div></div>
                    <div class="dm-sep"></div>
                    <div class="dm-stat"><div class="dm-stat-num green">★ 4.8</div><div class="dm-stat-lbl">Avg Rating</div></div>
                </div>
                <div class="dm-actions">
                    <button class="dm-btn-email"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>Send Email</button>
                    <button class="dm-btn-bk"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" /><rect x="9" y="3" width="6" height="4" rx="1" /></svg>View Bookings</button>
                    <button class="dm-btn-close" onclick="closeDetail()">Close</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        function openDetail(name, id, email, phone, joined, bookings, spent, status, initials, color, vehicles) {
            document.getElementById('dmName').textContent     = name;
            document.getElementById('dmId').textContent       = id;
            document.getElementById('dmEmail').textContent    = email;
            document.getElementById('dmPhone').textContent    = phone;
            document.getElementById('dmJoined').textContent   = joined;
            document.getElementById('dmBookings').textContent = bookings;
            document.getElementById('dmSpent').textContent    = spent;
            document.getElementById('dmVehicles').textContent = vehicles;

            const av = document.getElementById('dmAv');
            av.textContent = initials;
            av.style.background = color;

            document.getElementById('dmBand').style.background =
                'linear-gradient(135deg,' + color + '28 0%,transparent 70%)';

            const st = document.getElementById('dmStatus');
            st.innerHTML = '<span class="sdot"></span>' + status;
            st.className = 'status-pill pill-' + status.toLowerCase();

            document.getElementById('detailModal').classList.add('open');
        }

        function overlayClose(e) { if (e.target === e.currentTarget) closeDetail(); }
        function closeDetail()   { document.getElementById('detailModal').classList.remove('open'); }

        function removeRow(btn) {
            const tr = btn.closest('tr');
            tr.style.transition = 'opacity .3s, transform .3s';
            tr.style.opacity = '0';
            tr.style.transform = 'translateX(20px)';
            setTimeout(() => tr.remove(), 300);
        }

        document.querySelector('.search-input').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(r => {
                r.style.display = r.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>

</body>
</html>
