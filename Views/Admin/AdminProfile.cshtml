@model LUXURY_DRIVE.Models.AdminProfileViewModel
@{
    Layout = null;
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    ViewData["Title"] = "AdminProfile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Luxe Drive – Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/AdminProfile.css" asp-append-version="true" />
</head>
<body>

    <aside>
        <div class="brand">
            <div class="brand-icon">🚘</div>
            <div>
                <div class="brand-name">LUXE DRIVE</div>
                <div class="brand-role">Admin</div>
            </div>
        </div>
        <nav>
            <a asp-controller="Admin" asp-action="Dashboard" class="@(action == "Dashboard" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Adminbookings" class="@(action == "Adminbookings" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" /><rect x="9" y="3" width="6" height="4" rx="1" /><line x1="9" y1="12" x2="15" y2="12" /><line x1="9" y1="16" x2="13" y2="16" /></svg>
                Bookings
            </a>
            <a asp-controller="Admin" asp-action="AdminVehicles" class="@(action == "AdminVehicles" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="8" width="22" height="10" rx="2" /><path d="M5 8V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2" /><circle cx="7" cy="14" r="1" fill="currentColor" /><circle cx="17" cy="14" r="1" fill="currentColor" /></svg>
                Vehicles
            </a>
            <a asp-controller="Admin" asp-action="AdminCustomers" class="@(action == "AdminCustomers" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                Customers
            </a>
            <a asp-controller="Admin" asp-action="AdminProfile" class="@(action == "AdminProfile" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                Profile
            </a>
        </nav>
        <div class="user-footer">
            <div class="avatar">A</div>
            <div>
                <div class="user-name">Admin</div>
                <div class="user-email">admin@luxedrive.com</div>
            </div>
            <button onclick="window.location.href='/Authentication/Login'" class="logout-btn" title="Logout">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
            </button>
        </div>
    </aside>

    <main>
        <header>
            <div>
                <h1>Settings</h1>
                <p>Manage your account and preferences</p>
            </div>
        </header>

        <div class="content">

            <!-- ── Profile Banner Card ── -->
            <div class="profile-banner">
                <div class="banner-bg"></div>
                <div class="banner-body">
                    <div class="banner-avatar" id="bannerAvatar">A</div>
                    <div class="banner-info">
                        <div class="banner-name" id="bannerName">Admin</div>
                        <div class="banner-email" id="bannerEmail">admin@luxedrive.com</div>
                        <span class="banner-role">Super Admin</span>
                    </div>
                    <div class="banner-stats">
                        <div class="bstat">
                            <div class="bstat-num">21</div>
                            <div class="bstat-lbl">Bookings</div>
                        </div>
                        <div class="bstat-div"></div>
                        <div class="bstat">
                            <div class="bstat-num">8</div>
                            <div class="bstat-lbl">Customers</div>
                        </div>
                        <div class="bstat-div"></div>
                        <div class="bstat">
                            <div class="bstat-num">4</div>
                            <div class="bstat-lbl">Vehicles</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- ── Two-column grid ── -->
            <div class="settings-grid">

                <!-- LEFT: Profile Settings -->
                <div class="settings-card">
                    <form asp-controller="Admin" asp-action="UpdateProfile" method="post">
                        <div class="card-header">
                            <div class="card-icon">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            </div>
                            <div>
                                <div class="card-title">Profile Settings</div>
                                <div class="card-sub">Update your display information</div>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label asp-for="FullName">Full Name</label>
                                <input type="text" asp-for="FullName" class="form-input" placeholder="Your full name" oninput="liveUpdate()" />
                                <span asp-validation-for="FullName" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Email">Email Address</label>
                                <input type="email" asp-for="Email" class="form-input" placeholder="admin@example.com" oninput="liveUpdate()" />
                                <span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="PhoneNumber">Phone Number</label>
                                <input type="text" asp-for="PhoneNumber" class="form-input" placeholder="+91 XXXXX XXXXX" />
                                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label>Role</label>
                                <input type="text" class="form-input" value="Super Admin" disabled />
                            </div>
                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn-save">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
                                Save Changes
                            </button>
                            <span class="save-msg" id="profileMsg"></span>
                        </div>
                    </form>
                </div>

                <!-- RIGHT: Change Password -->
                <div class="settings-card">
                    <form asp-controller="Admin" asp-action="UpdatePassword" method="post">
                        <div class="card-header">
                            <div class="card-icon card-icon-orange">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                            </div>
                            <div>
                                <div class="card-title">Change Password</div>
                                <div class="card-sub">Update your login credentials</div>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group">
                                <label>Current Password</label>
                                <div class="pw-wrap">
                                    <input type="password" name="CurrentPassword" class="form-input" placeholder="Enter current password" id="pwCurrent" />
                                    <button class="pw-toggle" onclick="togglePw('pwCurrent', this)" type="button">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                    </button>
                                </div>
                                <span class="field-validation-valid text-danger" data-valmsg-for="CurrentPassword" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>New Password</label>
                                <div class="pw-wrap">
                                    <input type="password" name="NewPassword" class="form-input" placeholder="Enter new password" oninput="checkStrength()" id="pwNew" />
                                    <button class="pw-toggle" onclick="togglePw('pwNew', this)" type="button">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                    </button>
                                </div>
                                <span class="field-validation-valid text-danger" data-valmsg-for="NewPassword" data-valmsg-replace="true"></span>
                                <!-- Strength bar -->
                                <div class="strength-bar" id="strengthBar">
                                    <div class="strength-fill" id="strengthFill"></div>
                                </div>
                                <div class="strength-label" id="strengthLabel"></div>
                            </div>
                            <div class="form-group">
                                <label>Confirm New Password</label>
                                <div class="pw-wrap">
                                    <input type="password" name="ConfirmPassword" class="form-input" placeholder="Re-enter new password" id="pwConfirm" />
                                    <button class="pw-toggle" onclick="togglePw('pwConfirm', this)" type="button">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                    </button>
                                </div>
                                <span class="field-validation-valid text-danger" data-valmsg-for="ConfirmPassword" data-valmsg-replace="true"></span>
                            </div>
                        </div>

                        <div class="card-footer">
                            <button type="submit" class="btn-update">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                                Update Password
                            </button>
                            <span class="save-msg" id="pwMsg"></span>
                        </div>
                    </form>
                </div>

                <!-- Notifications Card -->
                <div class="settings-card">
                    <div class="card-header">
                        <div class="card-icon card-icon-blue">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" /><path d="M13.73 21a2 2 0 0 1-3.46 0" /></svg>
                        </div>
                        <div>
                            <div class="card-title">Notifications</div>
                            <div class="card-sub">Control what alerts you receive</div>
                        </div>
                    </div>

                    <div class="card-body notif-body">
                        <div class="toggle-row">
                            <div class="toggle-info">
                                <div class="toggle-title">New Bookings</div>
                                <div class="toggle-sub">Get notified when a customer places a booking</div>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" checked />
                                <span class="toggle-knob"></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-info">
                                <div class="toggle-title">Booking Cancellations</div>
                                <div class="toggle-sub">Alert when a booking is cancelled</div>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" checked />
                                <span class="toggle-knob"></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-info">
                                <div class="toggle-title">New Customer Registrations</div>
                                <div class="toggle-sub">Notify when a new customer signs up</div>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" />
                                <span class="toggle-knob"></span>
                            </label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-info">
                                <div class="toggle-title">Vehicle Maintenance Reminders</div>
                                <div class="toggle-sub">Scheduled service and maintenance alerts</div>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" checked />
                                <span class="toggle-knob"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Danger Zone Card -->
                <div class="settings-card danger-card">
                    <div class="card-header">
                        <div class="card-icon card-icon-red">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                        </div>
                        <div>
                            <div class="card-title">Danger Zone</div>
                            <div class="card-sub">Irreversible account actions</div>
                        </div>
                    </div>

                    <div class="card-body">
                        <div class="danger-row">
                            <div>
                                <div class="danger-title">Sign Out of All Devices</div>
                                <div class="danger-desc">Revoke all active sessions across all devices</div>
                            </div>
                            <button class="btn-danger-outline">Sign Out All</button>
                        </div>
                        <div class="danger-divider"></div>
                        <div class="danger-row">
                            <div>
                                <div class="danger-title">Deactivate Account</div>
                                <div class="danger-desc">Temporarily disable admin access to the panel</div>
                            </div>
                            <button class="btn-danger-fill">Deactivate</button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </main>

    <script>
        /* ── Live Banner Update ── */
        function liveUpdate() {
            const name  = document.getElementById('pName').value  || 'Admin';
            const email = document.getElementById('pEmail').value || 'admin@luxedrive.com';
            document.getElementById('bannerName').textContent  = name;
            document.getElementById('bannerEmail').textContent = email;
            document.getElementById('bannerAvatar').textContent = name.trim().charAt(0).toUpperCase();
        }

        /* ── Save Profile ── */
        function saveProfile() {
            const msg = document.getElementById('profileMsg');
            msg.textContent = '✓ Saved successfully';
            msg.className   = 'save-msg msg-ok';
            setTimeout(() => { msg.textContent = ''; msg.className = 'save-msg'; }, 3000);
        }

        /* ── Password toggle ── */
        function togglePw(id, btn) {
            const inp = document.getElementById(id);
            const show = inp.type === 'password';
            inp.type = show ? 'text' : 'password';
            btn.style.color = show ? 'var(--gold)' : '';
        }

        /* ── Password strength ── */
        function checkStrength() {
            const pw    = document.getElementById('pwNew').value;
            const fill  = document.getElementById('strengthFill');
            const label = document.getElementById('strengthLabel');
            const bar   = document.getElementById('strengthBar');

            if (!pw) { bar.style.display = 'none'; label.textContent = ''; return; }
            bar.style.display = 'block';

            let score = 0;
            if (pw.length >= 8)             score++;
            if (/[A-Z]/.test(pw))           score++;
            if (/[0-9]/.test(pw))           score++;
            if (/[^A-Za-z0-9]/.test(pw))    score++;

            const configs = [
                { w:'25%',  bg:'#e05c2e', txt:'Weak' },
                { w:'50%',  bg:'#f59e0b', txt:'Fair' },
                { w:'75%',  bg:'#3b82f6', txt:'Good' },
                { w:'100%', bg:'#2db568', txt:'Strong' },
            ];
            const c = configs[score - 1] || configs[0];
            fill.style.width      = c.w;
            fill.style.background = c.bg;
            label.textContent     = c.txt;
            label.style.color     = c.bg;
        }

        /* ── Update Password ── */
        function updatePassword() {
            const cur  = document.getElementById('pwCurrent').value;
            const nw   = document.getElementById('pwNew').value;
            const conf = document.getElementById('pwConfirm').value;
            const msg  = document.getElementById('pwMsg');

            if (!cur || !nw || !conf) {
                msg.textContent = '✕ All fields are required';
                msg.className   = 'save-msg msg-err';
            } else if (nw !== conf) {
                msg.textContent = '✕ Passwords do not match';
                msg.className   = 'save-msg msg-err';
            } else if (nw.length < 6) {
                msg.textContent = '✕ Password too short';
                msg.className   = 'save-msg msg-err';
            } else {
                msg.textContent = '✓ Password updated';
                msg.className   = 'save-msg msg-ok';
                document.getElementById('pwCurrent').value = '';
                document.getElementById('pwNew').value     = '';
                document.getElementById('pwConfirm').value = '';
                document.getElementById('strengthBar').style.display = 'none';
                document.getElementById('strengthLabel').textContent  = '';
            }
            setTimeout(() => { msg.textContent = ''; msg.className = 'save-msg'; }, 3500);
        }
    </script>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

</body>
</html>
