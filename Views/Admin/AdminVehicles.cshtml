    <script>
        let editingRow = null;

        /* ══════════════════════════════════════
           ADD VEHICLE INLINE FORM
           ══════════════════════════════════════ */

        // Toggle the collapsible add-form card open/closed
        function toggleAddForm() {
            const card = document.getElementById('addFormCard');
            card.classList.toggle('open');
            if (card.classList.contains('open')) {
                setTimeout(() => card.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 60);
            }
        }

        // Live image preview
        function afUpdatePreview() {
            const url = document.getElementById('afImg').value.trim();
            const imgEl = document.getElementById('afImgEl');
            const placeholder = document.getElementById('afImgPlaceholder');
            if (url) {
                imgEl.src = url;
                imgEl.classList.add('af-visible');
                placeholder.style.display = 'none';
            } else {
                imgEl.classList.remove('af-visible');
                placeholder.style.display = 'flex';
            }
        }

        // Reset all add-form fields
        function afReset() {
            ['afName','afSub','afPrice','afAcc','afSpeed','afHp','afMileage','afImg','afDesc']
                .forEach(id => document.getElementById(id).value = '');
            document.getElementById('afCat').value = 'Luxury';
            afUpdatePreview();
        }

        // Highlight a field with an error colour
        function afHighlight(id, msg) {
            const el = document.getElementById(id);
            el.style.borderColor = 'var(--orange)';
            el.placeholder = msg;
            el.focus();
            setTimeout(() => { el.style.borderColor = ''; }, 2200);
        }

        // Submit the add form → append a new table row
        function afSubmit() {
            const name    = document.getElementById('afName').value.trim();
            const sub     = document.getElementById('afSub').value.trim();
            const cat     = document.getElementById('afCat').value;
            const price   = document.getElementById('afPrice').value.trim();
            const acc     = document.getElementById('afAcc').value.trim();
            const speed   = document.getElementById('afSpeed').value.trim();
            const hp      = document.getElementById('afHp').value.trim();
            const mileage = document.getElementById('afMileage').value.trim();
            const img     = document.getElementById('afImg').value.trim();
            const desc    = document.getElementById('afDesc').value.trim();

            if (!name)  { afHighlight('afName',  'Vehicle name is required');  return; }
            if (!price) { afHighlight('afPrice', 'Price is required'); return; }

            const fallback = 'https://images.unsplash.com/photo-1503736334956-4c8f8e92946d?w=120&q=70&fit=crop';
            const catClass = 'cat-' + cat.toLowerCase();

            const tbody = document.getElementById('vehicleTableBody');
            const tr = document.createElement('tr');
            tr.style.animation = 'rowIn .4s ease both';

            tr.innerHTML = `
                <td>
                    <div class="vehicle-cell">
                        <div class="vehicle-thumb">
                            <img src="${img || fallback}" alt="${name}" />
                        </div>
                        <div>
                            <div class="vehicle-name">${name}</div>
                            <div class="vehicle-sub">${sub || '—'}</div>
                        </div>
                    </div>
                </td>
                <td><span class="cat-badge ${catClass}">${cat}</span></td>
                <td>
                    <div class="specs-cell">
                        <span class="spec-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>${acc || '—'}</span>
                        <span class="spec-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/></svg>${speed || '—'}</span>
                        <span class="spec-item"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>${hp || '—'}</span>
                    </div>
                </td>
                <td><span class="price-val">${price}</span></td>
                <td>
                    <div class="status-wrap">
                        <button class="badge badge-available" onclick="toggleStatus(event, this)">
                            Available
                            <svg class="badge-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
                        </button>
                        <div class="status-dropdown">
                            <div class="dropdown-label">Change Status</div>
                            <button class="dropdown-item item-available"   onclick="setStatus(this,'Available','badge-available')"><span class="dot dot-available"></span>Available</button>
                            <button class="dropdown-item item-rented"      onclick="setStatus(this,'Rented','badge-rented')"><span class="dot dot-rented"></span>Rented</button>
                            <button class="dropdown-item item-maintenance" onclick="setStatus(this,'Maintenance','badge-maintenance')"><span class="dot dot-maintenance"></span>Maintenance</button>
                        </div>
                    </div>
                </td>
                <td>
                    <div class="actions-cell">
                        <button class="action-btn" title="View"
                            onclick="viewVehicle('${name}','${cat}','${sub}','${price}','${acc || '—'}','${speed || '—'}','${hp || '—'}','${mileage || '—'}','${img || fallback}','${desc}')">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                        <button class="action-btn" title="Edit" onclick="editVehicle(this)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </button>
                        <button class="action-btn danger" title="Delete" onclick="deleteRow(this)">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                        </button>
                    </div>
                </td>`;

            tbody.appendChild(tr);

            // Brief gold flash on new row
            setTimeout(() => {
                tr.style.transition = 'background .4s ease';
                tr.style.background = 'rgba(201,168,76,0.1)';
                setTimeout(() => { tr.style.background = ''; }, 900);
            }, 100);

            // Scroll new row into view
            setTimeout(() => tr.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 200);

            // Reset + collapse form
            afReset();
            document.getElementById('addFormCard').classList.remove('open');
        }

        /* ══════════════════════════════════════
           STATUS DROPDOWN
           ══════════════════════════════════════ */
        function toggleStatus(e, badge) {
            e.stopPropagation();
            const wrap = badge.closest('.status-wrap');
            const isOpen = wrap.classList.contains('open');
            closeAllDropdowns();
            if (!isOpen) {
                const rect = badge.getBoundingClientRect();
                const dd = wrap.querySelector('.status-dropdown');
                dd.style.top  = (rect.bottom + 6) + 'px';
                dd.style.left = rect.left + 'px';
                if (rect.left + 172 > window.innerWidth - 8)
                    dd.style.left = (window.innerWidth - 172 - 8) + 'px';
                wrap.classList.add('open');
            }
        }

        function closeAllDropdowns() {
            document.querySelectorAll('.status-wrap.open').forEach(w => w.classList.remove('open'));
        }

        function setStatus(btn, label, badgeClass) {
            const e = window.event; if (e) e.stopPropagation();
            const wrap    = btn.closest('.status-wrap');
            const badge   = wrap.querySelector('.badge');
            const chevron = badge.querySelector('.badge-chevron');
            badge.textContent = label + ' ';
            badge.appendChild(chevron);
            badge.className = 'badge ' + badgeClass + ' badge-flash';
            badge.setAttribute('onclick', 'toggleStatus(event, this)');
            setTimeout(() => badge.classList.remove('badge-flash'), 500);
            wrap.classList.remove('open');
        }

        document.addEventListener('click', closeAllDropdowns);
        document.querySelector('.content').addEventListener('scroll', closeAllDropdowns);

        /* ══════════════════════════════════════
           VIEW MODAL
           ══════════════════════════════════════ */
        function viewVehicle(name, cat, sub, price, acc, speed, hp, mileage, img, desc) {
            document.getElementById('vmName').textContent  = name;
            document.getElementById('vmPrice').textContent = price + ' / day';
            document.getElementById('vmCat').textContent   = cat;
            document.getElementById('vmCat').className     = 'view-cat-badge cat-' + cat.toLowerCase();
            document.getElementById('vmImg').src           = img;
            document.getElementById('vmMeta').textContent  = sub;
            document.getElementById('vmDesc').textContent  = desc;
            document.getElementById('vmSpecs').innerHTML   =
                `<div class="vs-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><span>${acc}</span><small>0–100 km/h</small></div>
                 <div class="vs-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2z"/><path d="M12 6v6l4 2"/></svg><span>${speed}</span><small>Top Speed</small></div>
                 <div class="vs-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg><span>${hp}</span><small>Horsepower</small></div>
                 <div class="vs-item"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4"/><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg><span>${mileage}</span><small>Mileage</small></div>`;
            document.getElementById('viewModal').classList.add('open');
        }

        function closeViewModal(e)   { if (e.target === e.currentTarget) closeViewModalBtn(); }
        function closeViewModalBtn() { document.getElementById('viewModal').classList.remove('open'); }

        /* ══════════════════════════════════════
           EDIT MODAL
           ══════════════════════════════════════ */
        function editVehicle(btn) {
            editingRow = btn.closest('tr');
            document.getElementById('editModalTitle').textContent = 'Edit Vehicle';

            const name    = editingRow.querySelector('.vehicle-name').textContent;
            const sub     = editingRow.querySelector('.vehicle-sub').textContent;
            const price   = editingRow.querySelector('.price-val').textContent;
            const specs   = editingRow.querySelectorAll('.spec-item');
            const catText = editingRow.querySelector('.cat-badge').textContent.trim();
            const imgSrc  = editingRow.querySelector('.vehicle-thumb img').src;

            document.getElementById('fName').value    = name;
            document.getElementById('fSub').value     = sub;
            document.getElementById('fPrice').value   = price;
            document.getElementById('fCat').value     = catText;
            document.getElementById('fImg').value     = imgSrc;
            document.getElementById('fMileage').value = '';
            document.getElementById('fDesc').value    = '';

            if (specs[0]) document.getElementById('fAcc').value   = specs[0].textContent.trim();
            if (specs[1]) document.getElementById('fSpeed').value = specs[1].textContent.trim();
            if (specs[2]) document.getElementById('fHp').value    = specs[2].textContent.trim();

            document.getElementById('editModal').classList.add('open');
        }

        function saveVehicle() {
            const name  = document.getElementById('fName').value.trim();
            const sub   = document.getElementById('fSub').value.trim();
            const cat   = document.getElementById('fCat').value;
            const price = document.getElementById('fPrice').value.trim();
            const acc   = document.getElementById('fAcc').value.trim();
            const speed = document.getElementById('fSpeed').value.trim();
            const hp    = document.getElementById('fHp').value.trim();
            const img   = document.getElementById('fImg').value.trim();

            if (!name || !price) { alert('Vehicle name and price are required.'); return; }
            if (!editingRow) return;

            const catClass = 'cat-' + cat.toLowerCase();
            editingRow.querySelector('.vehicle-name').textContent = name;
            editingRow.querySelector('.vehicle-sub').textContent  = sub;
            editingRow.querySelector('.price-val').textContent    = price;
            const catBadge = editingRow.querySelector('.cat-badge');
            catBadge.textContent = cat;
            catBadge.className   = 'cat-badge ' + catClass;
            if (img) editingRow.querySelector('.vehicle-thumb img').src = img;
            const specs = editingRow.querySelectorAll('.spec-item');
            if (specs[0] && acc)   specs[0].lastChild.textContent = acc;
            if (specs[1] && speed) specs[1].lastChild.textContent = speed;
            if (specs[2] && hp)    specs[2].lastChild.textContent = hp;

            closeEditModalBtn();
            editingRow.style.transition = 'background .3s ease';
            editingRow.style.background = 'rgba(201,168,76,0.08)';
            setTimeout(() => { editingRow.style.background = ''; }, 800);
            editingRow = null;
        }

        function closeEditModal(e)   { if (e.target === e.currentTarget) closeEditModalBtn(); }
        function closeEditModalBtn() { document.getElementById('editModal').classList.remove('open'); }

        /* ══════════════════════════════════════
           DELETE & SEARCH
           ══════════════════════════════════════ */
        function deleteRow(btn) {
            const tr = btn.closest('tr');
            tr.style.transition = 'opacity .3s ease, transform .3s ease';
            tr.style.opacity = '0';
            tr.style.transform = 'translateX(20px)';
            setTimeout(() => tr.remove(), 300);
        }

        document.querySelector('.search-input').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });
    </script>

</body>
</html>
