@{
    Layout = null;
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    ViewData["Title"] = "Adminbookings";
    bool openAddForm = ViewBag.OpenAddForm == true;
    bool openEditModal = ViewBag.OpenEditModal == true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Luxe Drive – Bookings Management</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Adminbookings.css" asp-append-version="true" />
</head>
<body>

    <aside>
        <div class="brand">
            <div class="brand-icon">🚘</div>
            <div>
                <div class="brand-name">LUXE DRIVE</div>
                <div class="brand-role">Admin</div>
            </div>
        </div>
        <nav>
            <a asp-controller="Admin" asp-action="Dashboard" class="@(action == "Dashboard" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /></svg>
                Dashboard
            </a>
            <a asp-controller="Admin" asp-action="Adminbookings" class="@(action == "Adminbookings" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2" /><rect x="9" y="3" width="6" height="4" rx="1" /><line x1="9" y1="12" x2="15" y2="12" /><line x1="9" y1="16" x2="13" y2="16" /></svg>
                Bookings
            </a>
            <a asp-controller="Admin" asp-action="AdminVehicles" class="@(action == "AdminVehicles" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="8" width="22" height="10" rx="2" /><path d="M5 8V6a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v2" /><circle cx="7" cy="14" r="1" fill="currentColor" /><circle cx="17" cy="14" r="1" fill="currentColor" /></svg>
                Vehicles
            </a>
            <a asp-controller="Admin" asp-action="AdminCustomers" class="@(action == "AdminCustomers" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                Customers
            </a>
            <a asp-controller="Admin" asp-action="AdminProfile" class="@(action == "AdminProfile" ? "active" : "")">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                Profile
            </a>
        </nav>
        <div class="user-footer">
            <div class="avatar">A</div>
            <div>
                <div class="user-name">Admin</div>
                <div class="user-email">admin@luxedrive.com</div>
            </div>
            <button onclick="window.location.href='/Authentication/Login'" class="logout-btn" title="Logout">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" y1="12" x2="9" y2="12" />
                </svg>
            </button>
        </div>
    </aside>

    <main>
        <header>
            <div>
                <h1>Bookings Management</h1>
                <p>View and manage all customer bookings</p>
            </div>
            <div class="header-actions">
                <button class="btn-filter" onclick="document.querySelector('.search-input').focus()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3" /></svg>
                    Filter
                </button>
                <button class="btn-export" style="background-color: var(--surface2, #2a2a3e); border: 1px solid var(--border, #3a3a4e);" onclick="window.location.href='/Admin/ExportBookingsToPdf'">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    Export
                </button>
                <button class="btn-export" onclick="toggleAddBookingForm()">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    Add Booking
                </button>
            </div>
        </header>

        <div class="content">
            @if (TempData["EmailStatus"] != null)
            {
                var emailMsg = TempData["EmailStatus"].ToString();
                var isError = emailMsg.StartsWith("Error");
                <div style="padding: 12px 20px; background: @(isError ? "rgba(224,92,46,.1)" : "rgba(45,181,104,.1)"); color: @(isError ? "#e05c2e" : "#2db568"); border-radius: 8px; margin-bottom: 20px; border: 1px solid @(isError ? "rgba(224,92,46,.2)" : "rgba(45,181,104,.2)"); font-size: 13px; font-weight: 600;">
                    @emailMsg
                </div>
            }

            <!-- ADD BOOKING FORM -->
            <div id="addBookingCard" style="background:var(--surface,#1a1a2e);border:1px solid var(--border,#2a2a3e);border-radius:14px;margin-bottom:22px;overflow:hidden;display:@(openAddForm ? "block" : "none")">
                <form asp-controller="Admin" asp-action="AddBooking" method="post">
                    <div style="padding:16px 20px;border-bottom:1px solid var(--border,#2a2a3e);font-weight:700;font-size:13.5px;color:#fff">Add New Booking</div>
                    <div style="padding:18px 20px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px">
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">First Name *</label>
                            <input type="text" name="FirstName" class="form-input" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="First name" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Last Name *</label>
                            <input type="text" name="LastName" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="Last name" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Email *</label>
                            <input type="email" name="Email" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="Email" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Phone *</label>
                            <input type="text" name="Phone" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="Phone" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">License Number *</label>
                            <input type="text" name="LicenseNumber" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="License no." />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">License Expiry *</label>
                            <input type="date" name="LicenseExpiryDate" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Pickup Date *</label>
                            <input type="date" name="PickupDate" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Pickup Time *</label>
                            <input type="text" name="PickupTime" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="e.g. 10:00 AM" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Number of Days *</label>
                            <input type="number" name="NumberOfDays" min="1" max="30" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px" placeholder="Days" />
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Vehicle</label>
                            <select name="VehicleId" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px">
                                <option value="">-- Select Vehicle --</option>
                                @if (ViewBag.Vehicles != null)
                                {
                                    foreach (var v in ViewBag.Vehicles)
                                    {
                                        <option value="@v.VehicleId">@v.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div>
                            <label style="font-size:10px;font-weight:700;color:#888;text-transform:uppercase;display:block;margin-bottom:5px">Customer</label>
                            <select name="UserId" style="width:100%;padding:8px 11px;background:#111;border:1px solid #2a2a3e;border-radius:7px;color:#fff;font-size:12.5px">
                                <option value="">-- Select Customer --</option>
                                @if (ViewBag.Users != null)
                                {
                                    foreach (var u in ViewBag.Users)
                                    {
                                        <option value="@u.UserId">@u.FullName (@u.Email)</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    <div style="padding:0 20px 18px;display:flex;justify-content:flex-end;gap:10px">
                        <button type="button" onclick="toggleAddBookingForm()" style="padding:8px 15px;border-radius:7px;border:1px solid #2a2a3e;background:transparent;color:#888;font-size:12px;cursor:pointer">Cancel</button>
                        <button type="submit" style="padding:8px 18px;border-radius:7px;border:none;background:#2db568;color:#fff;font-size:12px;font-weight:700;cursor:pointer">✓ Add Booking</button>
                    </div>
                </form>
            </div>

            <div class="search-wrap">
                <span class="search-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                </span>
                <input class="search-input" type="text" placeholder="Search bookings..." />
            </div>

            <div class="table-card">
                <table>
                    <thead>
                        <tr>
                            <th>CUSTOMER</th>
                            <th>VEHICLE</th>
                            <th>DURATION</th>
                            <th>AMOUNT</th>
                            <th>STATUS</th>
                            <th>ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (ViewBag.Bookings != null)
                    {
                        foreach (var booking in ViewBag.Bookings)
                        {
                            var days = booking.NumberOfDays;
                            var amount = "—";
                            decimal priceValue = 0;
                            if (booking.Vehicle != null && decimal.TryParse(booking.Vehicle.PriceDay.Replace("₹", "").Replace(",", "").Trim(), out priceValue))
                            {
                                amount = "₹" + (priceValue * days).ToString("N0");
                            }

                            <tr>
                                <td>
                                    <div class="customer-cell">
                                        <span class="customer-name">@(booking.User?.FullName ?? booking.FirstName + " " + booking.LastName)</span>
                                        <span class="customer-email">@(booking.User?.Email ?? booking.Email)</span>
                                    </div>
                                </td>
                                <td>
                                    <div class="vehicle-cell">
                                        <div class="vehicle-thumb">
                                            <img src="@(booking.Vehicle?.ImageUrl ?? "https://images.unsplash.com/photo-1606664515524-ed2f786a0bd6?w=120&q=70&fit=crop")" alt="@(booking.Vehicle?.Name)" />
                                        </div>
                                        <div>
                                            <div class="vehicle-name">@(booking.Vehicle?.Name ?? "Unknown Vehicle")</div>
                                            <div class="vehicle-plate">@booking.LicenseNumber</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="duration-days">@days days</div>
                                    <div class="duration-range">@booking.PickupDate.ToString("dd MMM yyyy") – @booking.PickupDate.AddDays(days).ToString("dd MMM yyyy")</div>
                                </td>
                                <td><span class="amount-val">@amount</span></td>
                                <td>
                                    <div class="status-wrap">
                                        @{
                                            var st = booking.Status ?? "Pending";
                                            var badgeClass = "badge-" + st.ToLower();
                                        }
                                        <button class="badge @badgeClass" onclick="toggleStatus(event, this, @booking.RentId)">
                                            @st
                                            <svg class="badge-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9" /></svg>
                                        </button>
                                    </div>
                                </td>
                                <td>
                                    <div class="actions-cell">
                                        <button class="action-btn" title="View"
                                                onclick="openBooking('@booking.RentId','@((booking.User?.FullName ?? booking.FirstName + " " + booking.LastName).Replace("'", "\\'"))','@((booking.User?.Email ?? booking.Email).Replace("'", "\\'"))','@booking.Phone','@((booking.Vehicle?.Name ?? "").Replace("'", "\\'"))','@booking.LicenseNumber','@((booking.Vehicle?.Category ?? "Luxury").Replace("'", "\\'"))','@(booking.Vehicle?.ImageUrl ?? "")','@booking.PickupDate.ToString("dd MMM yyyy")','@booking.PickupDate.AddDays(days).ToString("dd MMM yyyy")','@days days','@amount','@(booking.Status ?? "Pending")','')">
                                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                        </button>
                                        <form method="post" asp-action="SendBookingEmail" style="display:inline;" onsubmit="return confirm('Do you want to manually send the booking confirmation email to this customer?');">
                                            <input type="hidden" name="id" value="@booking.RentId" />
                                            <button type="submit" class="action-btn" title="Send Email">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
                                            </button>
                                        </form>
                                        <form method="post" asp-action="DeleteBooking" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this booking?');">
                                            <input type="hidden" name="id" value="@booking.RentId" />
                                            <button type="submit" class="action-btn danger" title="Delete">
                                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2" /></svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </main>



    <!-- Shared status dropdown portal -->
    <div id="statusDropdown" class="status-dropdown">
        <div class="dropdown-label">Change Status</div>
        <button class="dropdown-item item-confirmed" onclick="applyStatus('Confirmed','badge-confirmed')"><span class="dot dot-confirmed"></span>Confirmed</button>
        <button class="dropdown-item item-pending" onclick="applyStatus('Pending','badge-pending')"><span class="dot dot-pending"></span>Pending</button>
        <button class="dropdown-item item-active" onclick="applyStatus('Active','badge-active')"><span class="dot dot-active"></span>Active</button>
        <button class="dropdown-item item-cancelled" onclick="applyStatus('Cancelled','badge-cancelled')"><span class="dot dot-cancelled"></span>Cancelled</button>
    </div>

    <!-- ══════════════════════════════════════════
         BOOKING DETAIL MODAL
    ══════════════════════════════════════════ -->
    <div class="bm-overlay" id="bookingModal" onclick="overlayClose(event)">
        <div class="bm-modal">

            <button class="bm-close" onclick="closeBooking()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </button>

            <!-- LEFT: vehicle photo + customer card -->
            <div class="bm-left">
                <div class="bm-img-wrap">
                    <img id="bmVehicleImg" src="" alt="" />
                    <span class="bm-cat-badge" id="bmCatBadge"></span>
                </div>
                <div class="bm-customer-card">
                    <div class="bm-cust-av" id="bmCustAv"></div>
                    <div class="bm-cust-info">
                        <div class="bm-cust-name" id="bmCustName"></div>
                        <div class="bm-cust-email" id="bmCustEmail"></div>
                        <div class="bm-cust-phone" id="bmCustPhone"></div>
                    </div>
                </div>
            </div>

            <!-- RIGHT: booking details -->
            <div class="bm-right">

                <div class="bm-head">
                    <div>
                        <div class="bm-id" id="bmId"></div>
                        <div class="bm-vehicle-name" id="bmVehicleName"></div>
                        <div class="bm-plate" id="bmPlate"></div>
                    </div>
                    <span class="bm-pill" id="bmStatus"></span>
                </div>

                <div class="bm-sep"></div>

                <div class="bm-grid">
                    <div class="bm-cell">
                        <div class="bm-cell-icon bm-ic-gold">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                        </div>
                        <div>
                            <div class="bm-cell-lbl">Pick-up</div>
                            <div class="bm-cell-val" id="bmPickup"></div>
                        </div>
                    </div>
                    <div class="bm-cell">
                        <div class="bm-cell-icon bm-ic-gold">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                        </div>
                        <div>
                            <div class="bm-cell-lbl">Return</div>
                            <div class="bm-cell-val" id="bmReturn"></div>
                        </div>
                    </div>
                    <div class="bm-cell">
                        <div class="bm-cell-icon bm-ic-blue">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                        </div>
                        <div>
                            <div class="bm-cell-lbl">Duration</div>
                            <div class="bm-cell-val" id="bmDuration"></div>
                        </div>
                    </div>
                    <div class="bm-cell">
                        <div class="bm-cell-icon bm-ic-green">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" /></svg>
                        </div>
                        <div>
                            <div class="bm-cell-lbl">Total Amount</div>
                            <div class="bm-cell-val bm-amount" id="bmAmount"></div>
                        </div>
                    </div>
                </div>

                <div class="bm-sep"></div>

                <div class="bm-notes">
                    <div class="bm-notes-title">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                        Special Notes
                    </div>
                    <div class="bm-notes-body" id="bmNotes"></div>
                </div>

                <div class="bm-actions">
                    <button class="bm-btn-confirm" id="bmBtnConfirm" onclick="quickConfirm()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" /></svg>
                        Confirm
                    </button>
                    <button class="bm-btn-cancel" id="bmBtnCancel" onclick="quickCancel()">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                        Cancel Booking
                    </button>
                    <button class="bm-btn-close" onclick="closeBooking()">Close</button>
                </div>

            </div>
        </div>
    </div>

    <script>
        /* ══ ADD BOOKING TOGGLE ══ */
        function toggleAddBookingForm() {
            const card = document.getElementById('addBookingCard');
            card.style.display = card.style.display === 'none' ? 'block' : 'none';
        }



        /* ══ STATUS DROPDOWN ══ */
        let activeBadge = null;
        let activeBookingId = null;

        function toggleStatus(e, badge, id) {
            e.stopPropagation();
            const dd = document.getElementById('statusDropdown');
            if (activeBadge === badge && dd.classList.contains('open')) { closeAll(); return; }
            closeAll();
            activeBadge = badge;
            activeBookingId = id;
            const rect = badge.getBoundingClientRect();
            let left = rect.left;
            if (left + 172 > window.innerWidth - 8) left = window.innerWidth - 172 - 8;
            dd.style.top  = (rect.bottom + 6) + 'px';
            dd.style.left = left + 'px';
            dd.classList.add('open');
            badge.closest('.status-wrap').classList.add('open');
        }

        async function applyStatus(label, badgeClass) {
            if (!activeBadge || !activeBookingId) return;
            
            // Capture locally to survive the async yield, because the click 
            // event will bubble to document and trigger closeAll() which nulls them.
            const targetBadge = activeBadge;
            const targetId = activeBookingId;
            
            try {
                const fd = new FormData();
                fd.append("id", targetId);
                fd.append("status", label);
                
                const res = await fetch('/Admin/UpdateBookingStatus', { method: 'POST', body: fd });
                if (!res.ok) {
                    const txt = await res.text();
                    throw new Error("HTTP " + res.status + " - " + txt);
                }
                
                const data = await res.json();
                if (data && data.success === false) {
                    throw new Error(data.message || "Unknown server error");
                }
                
                const chevron = targetBadge.querySelector('.badge-chevron');
                if (!chevron) throw new Error("Chevron SVG not found!");
                
                targetBadge.innerHTML = '';
                targetBadge.appendChild(document.createTextNode(label + ' '));
                targetBadge.appendChild(chevron);
                targetBadge.className = 'badge ' + badgeClass + ' badge-flash';
                setTimeout(() => targetBadge && targetBadge.classList.remove('badge-flash'), 500);
            } catch (err) {
                alert("Error updating status: " + err.message);
                console.error(err);
            }
            closeAll();
        }

        function closeAll() {
            document.getElementById('statusDropdown').classList.remove('open');
            document.querySelectorAll('.status-wrap.open').forEach(w => w.classList.remove('open'));
            activeBadge = null;
        }

        document.addEventListener('click', closeAll);
        document.querySelector('.content').addEventListener('scroll', closeAll);

        document.querySelector('.search-input').addEventListener('input', function () {
            const q = this.value.toLowerCase();
            document.querySelectorAll('tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
            });
        });

        /* ══ BOOKING DETAIL MODAL ══ */
        const catColors = {
            luxury:   { bg:'rgba(201,168,76,.2)',  color:'#c9a84c' },
            sports:   { bg:'rgba(59,130,246,.2)',   color:'#3b82f6' },
            electric: { bg:'rgba(168,85,247,.2)',   color:'#a855f7' },
            suv:      { bg:'rgba(45,181,104,.2)',   color:'#2db568' },
        };
        const pillMap = {
            confirmed: 'bm-pill-confirmed',
            pending:   'bm-pill-pending',
            active:    'bm-pill-active',
            cancelled: 'bm-pill-cancelled',
        };

        function openBooking(id, custName, custEmail, custPhone,
                             vehicleName, plate, category, imgSrc,
                             pickup, ret, duration, amount, status, notes) {

            /* ─ left pane ─ */
            document.getElementById('bmVehicleImg').src = imgSrc;

            const cc = catColors[category.toLowerCase()] || catColors.luxury;
            const badge = document.getElementById('bmCatBadge');
            badge.textContent      = category;
            badge.style.background = cc.bg;
            badge.style.color      = cc.color;

            const initials = custName.split(' ').map(w=>w[0]).join('').substring(0,2).toUpperCase();
            const av = document.getElementById('bmCustAv');
            av.textContent      = initials;
            av.style.background = cc.color;

            document.getElementById('bmCustName').textContent  = custName;
            document.getElementById('bmCustEmail').textContent = custEmail;
            document.getElementById('bmCustPhone').textContent = custPhone;

            /* ─ right pane ─ */
            document.getElementById('bmId').textContent          = '#' + id;
            document.getElementById('bmVehicleName').textContent  = vehicleName;
            document.getElementById('bmPlate').textContent        = plate;
            document.getElementById('bmPickup').textContent       = pickup;
            document.getElementById('bmReturn').textContent       = ret;
            document.getElementById('bmDuration').textContent     = duration;
            document.getElementById('bmAmount').textContent       = amount;
            document.getElementById('bmNotes').textContent        = notes || '—';

            const pill = document.getElementById('bmStatus');
            pill.textContent = status;
            pill.className   = 'bm-pill ' + (pillMap[status.toLowerCase()] || 'bm-pill-pending');

            /* ─ button visibility ─ */
            const isCancelled = status.toLowerCase() === 'cancelled';
            const isConfirmed = status.toLowerCase() === 'confirmed';
            document.getElementById('bmBtnConfirm').style.display = (isCancelled || isConfirmed) ? 'none' : 'inline-flex';
            document.getElementById('bmBtnCancel').style.display  = isCancelled ? 'none' : 'inline-flex';

            document.getElementById('bookingModal').classList.add('open');
        }

        function overlayClose(e) { if (e.target === e.currentTarget) closeBooking(); }
        function closeBooking()  { document.getElementById('bookingModal').classList.remove('open'); }

        function quickConfirm() {
            const pill = document.getElementById('bmStatus');
            pill.textContent = 'Confirmed';
            pill.className   = 'bm-pill bm-pill-confirmed';
            document.getElementById('bmBtnConfirm').style.display = 'none';
        }

        function quickCancel() {
            const pill = document.getElementById('bmStatus');
            pill.textContent = 'Cancelled';
            pill.className   = 'bm-pill bm-pill-cancelled';
            document.getElementById('bmBtnConfirm').style.display = 'none';
            document.getElementById('bmBtnCancel').style.display  = 'none';
        }
    </script>

</body>
</html>
