@{
    Layout = null;
    ViewData["Title"] = "Car Rent";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>@ViewData["Title"] - LUXE DRIVE</title>

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/carrent.css" asp-append-version="true" />

    <style>

        /* NAVBAR */

        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 40px;
            background: #000;
            border-bottom: 1px solid #333;
        }

        /* LOGO */

        .nav-logo {
            display: flex;
            align-items: center;
            gap: 14px;
            text-decoration: none;
        }

        /* ICON BOX */

        .logo-icon {
            width: 48px;
            height: 48px;
            border: 2px solid #d4af37;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* SHIELD ICON */

        .shield {
            width: 16px;
            height: 20px;
            border: 2px solid #d4af37;
            border-radius: 6px 6px 10px 10px;
        }

        /* LOGO TEXT */

        .logo-title {
            font-size: 20px;
            font-weight: 600;
            letter-spacing: 2px;
            color: #d4af37;
            font-family: 'Montserrat',sans-serif;
        }

        .logo-sub {
            font-size: 12px;
            color: #cfcfcf;
            letter-spacing: 1px;
            margin-top: 2px;
        }

        .nav-back {
            display: flex;
            align-items: center;
            gap: 6px;
            color: #d4af37;
            cursor: pointer;
            font-size: 14px;
            font-family: 'Montserrat',sans-serif;
            transition: 0.3s;
        }

            .nav-back:hover {
                color: #fff;
                transform: translateX(-3px);
            }

    </style>

</head>

<body>

    <!-- NAVBAR WITH LOGO -->

    <nav>

        <a asp-controller="Home" asp-action="Index" class="nav-logo">

            <div class="logo-icon">
                <div class="shield"></div>
            </div>

            <div>
                <div class="logo-title">LUXE DRIVE</div>
                <div class="logo-sub">Premium Rentals</div>
            </div>

        </a>

        <span class="nav-back" onclick="history.back()">

            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2">

                <polyline points="15 18 9 12 15 6" />

            </svg>

            Back

        </span>

    </nav>


    <div class="book-wrap">

        <!-- LEFT FORM -->
        <div class="book-form-col">

            <!-- PERSONAL INFO -->
            <div class="form-section">

                <div class="form-section-title"> Personal Information</div>

                <div class="form-row">

                    <div class="form-group">
                        <label>First Name *</label>
                        <input type="text" class="form-input" id="firstName">
                    </div>

                    <div class="form-group">
                        <label>Last Name *</label>
                        <input type="text" class="form-input" id="lastName">
                    </div>

                </div>

                <div class="form-row">

                    <div class="form-group">
                        <label>Email *</label>
                        <input type="email" class="form-input" id="email">
                    </div>

                    <div class="form-group">
                        <label>Phone *</label>
                        <input type="tel" class="form-input" id="phone">
                    </div>

                    <div class="form-group">
                        <label>Driving License Number *</label>
                        <input type="text" class="form-input" id="license">
                    </div>

                    <div class="form-group">
                        <label>License Expiry Date</label>
                        <input type="date" class="form-input" id="licenseExpiry">
                    </div>

                </div>

            </div>

         

            <!-- RENTAL DETAILS -->
            <div class="form-section">

                <div class="form-section-title"> Rental Details</div>

                <div class="form-row">

                    

                </div>

                <div class="form-row">

                    <div class="form-group">
                        <label>Pickup Date *</label>
                        <input type="date" class="form-input">
                    </div>

                    <div class="form-group">
                        <label>Pickup Time</label>

                        <select class="form-select">
                            <option>09:00 AM</option>
                            <option>10:00 AM</option>
                            <option>11:00 AM</option>
                            <option>12:00 PM</option>
                            <option>02:00 PM</option>
                            <option>04:00 PM</option>
                        </select>

                    </div>

                </div>

                <div class="form-row">


                    <div class="form-group">
                        <label>Number of Days</label>
                        <input type="number" class="form-input" value="1">
                    </div>

                </div>

            </div>


            <!-- TERMS -->
          

        </div>

        <!-- RIGHT SUMMARY -->
        <div class="book-summary-col">

            <div class="summary-card">

                <img class="summary-car-img"
                     src="https://images.unsplash.com/photo-1555215695-3004980ad54e?w=800&q=80">

                <div class="summary-body">

                    <div class="summary-car-name">BMW M5</div>
                    <div class="summary-car-type">Luxury</div>

                    <div class="summary-line">
                        <span>Price / Day</span>
                        <span>₹10,000</span>
                    </div>

                    <div class="summary-line">
                        <span>Days</span>
                        <span>1</span>
                    </div>

                    <div class="summary-total-block">
                        <span>Total</span>
                        <span>₹10,000</span>
                    </div>

                </div>

                <div class="btn-confirm-wrap">
                    <button class="btn-confirm">
                        Confirm Booking →
                    </button>
                </div>

            </div>

        </div>

    </div>

    <script src="~/js/carrent.js" asp-append-version="true"></script>

</body>
</html>