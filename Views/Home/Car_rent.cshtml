@{
        Layout = null;

    ViewData["Title"] = "Car_rent";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Your Car – LUXE DRIVE</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/carrent.css" asp-append-version="true" />

</head>
<body>

<div class="page-transition" id="pageTransition"></div>

<!-- NAV -->
<nav>
    <a href="home.html" class="nav-logo">
        <div class="brand">LUXE DRIVE</div>
        <div class="sub">Premium Rentals</div>
    </a>
    <span class="nav-back" onclick="history.back()">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Back
    </span>
</nav>

<!-- BREADCRUMB -->
<div class="breadcrumb">
    <a href="home.html">Home</a>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <a href="home.html">Fleet</a>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <span id="breadCar" class="bc-current">Select a Car</span>
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    <span class="bc-current">Book</span>
</div>

<!-- CAR QUICK-SELECT -->
<div class="car-selector-bar" id="carSelectorBar"></div>

<!-- STEPS -->
<div class="steps-bar">
    <div class="step active" id="step1"><div class="step-num">1</div><div class="step-label">Details</div></div>
    <div class="step-line" id="line1"></div>
    <div class="step active" id="step2"><div class="step-num">2</div><div class="step-label">Schedule</div></div>
    <div class="step-line" id="line2"></div>
    <div class="step" id="step3"><div class="step-num">3</div><div class="step-label">Confirm</div></div>
</div>

<!-- BOOKING WRAP -->
<div class="book-wrap">

    <!-- LEFT: FORM -->
    <div class="book-form-col">

        <!-- PERSONAL INFO -->
        <div class="form-section">
            <div class="form-section-title">
                <div class="form-section-title-icon">👤</div>
                Personal Information
            </div>
            <div class="form-section-sub">Tell us who's driving</div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">First Name *</label>
                    <input type="text" class="form-input" id="firstName" placeholder="First name">
                    <div class="field-error" id="errFirstName">First name is required</div>
                </div>
                <div class="form-group">
                    <label class="form-label">Last Name *</label>
                    <input type="text" class="form-input" id="lastName" placeholder="Last name">
                    <div class="field-error" id="errLastName">Last name is required</div>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Email *</label>
                    <input type="email" class="form-input" id="email" placeholder="your@email.com">
                    <div class="field-error" id="errEmail">Valid email required</div>
                </div>
                <div class="form-group">
                    <label class="form-label">Phone *</label>
                    <input type="tel" class="form-input" id="phone" placeholder="+91 XXXXX XXXXX">
                    <div class="field-error" id="errPhone">Phone number is required</div>
                </div>
            </div>
        </div>

        <!-- SCHEDULE -->
        <div class="form-section">
            <div class="form-section-title">
                <div class="form-section-title-icon">📅</div>
                Rental Schedule
            </div>
            <div class="form-section-sub">Choose your pickup date and duration</div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Pickup Date *</label>
                    <input type="date" class="form-input" id="pickupDate" onchange="updateDates()">
                    <div class="field-error" id="errPickup">Pickup date is required</div>
                </div>
                <div class="form-group">
                    <label class="form-label">Pickup Time</label>
                    <select class="form-select" id="pickupTime">
                        <option value="09:00">09:00 AM</option>
                        <option value="10:00">10:00 AM</option>
                        <option value="11:00">11:00 AM</option>
                        <option value="12:00">12:00 PM</option>
                        <option value="14:00">02:00 PM</option>
                        <option value="16:00">04:00 PM</option>
                        <option value="18:00">06:00 PM</option>
                    </select>
                </div>
            </div>

            <div class="form-group" style="margin-bottom:1rem">
                <label class="form-label">Number of Days *</label>
                <div class="days-picker">
                    <button class="days-btn" type="button" onclick="changeDays(-1)">−</button>
                    <input type="number" class="days-input" id="daysInput" value="1" min="1" max="30" oninput="updateDates()">
                    <button class="days-btn" type="button" onclick="changeDays(1)">+</button>
                </div>
            </div>

            <div class="date-display">
                <div>
                    <div class="date-col-label">Pickup</div>
                    <div class="date-col-val" id="pickupDisplay">—</div>
                </div>
                <div class="date-arrow">→</div>
                <div>
                    <div class="date-col-label">Return</div>
                    <div class="date-col-val" id="returnDisplay">—</div>
                </div>
            </div>
        </div>

        <!-- EXTRAS -->
        <div class="form-section">
            <div class="form-section-title">
                <div class="form-section-title-icon">✨</div>
                Additional Services
            </div>
            <div class="form-section-sub">Optional add-ons for your journey</div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Driver Option</label>
                    <select class="form-select" id="driverOpt" onchange="updateSummary()">
                        <option value="0">Self Drive (Free)</option>
                        <option value="1500">With Driver (+₹1,500/day)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Insurance</label>
                    <select class="form-select" id="insOpt" onchange="updateSummary()">
                        <option value="0">Basic (Included)</option>
                        <option value="800">Premium (+₹800/day)</option>
                        <option value="1500">Platinum (+₹1,500/day)</option>
                    </select>
                </div>
            </div>

            <div class="form-row full">
                <div class="form-group">
                    <label class="form-label">Special Requests</label>
                    <input type="text" class="form-input" id="specialReq" placeholder="Child seat, GPS, etc.">
                </div>
            </div>
        </div>

    </div>

    <!-- RIGHT: SUMMARY -->
    <div class="book-summary-col">
        <div class="summary-card">
            <img class="summary-car-img" id="summaryImg"
                 src="https://images.unsplash.com/photo-1555215695-3004980ad54e?w=800&q=80" alt="Car">
            <div class="summary-body">
                <div class="summary-car-name" id="summaryName">BMW M5</div>
                <div class="summary-car-type" id="summaryType">Luxury</div>

                <div class="summary-line">
                    <span class="summary-line-key">Price / Day</span>
                    <span class="summary-line-val" id="sumPPD">₹10,000</span>
                </div>
                <div class="summary-line">
                    <span class="summary-line-key">Days</span>
                    <span class="summary-line-val" id="sumDays">1</span>
                </div>
                <div class="summary-line">
                    <span class="summary-line-key">Driver</span>
                    <span class="summary-line-val" id="sumDriver">Free</span>
                </div>
                <div class="summary-line">
                    <span class="summary-line-key">Insurance</span>
                    <span class="summary-line-val" id="sumIns">Included</span>
                </div>

                <div class="summary-total-block">
                    <span class="total-label">Total</span>
                    <span class="total-amount" id="sumTotal">₹10,000</span>
                </div>
            </div>

            <div class="trust-badges">
                <div class="trust-badge"><span class="trust-badge-icon">🛡</span>100% Secure Booking</div>
                <div class="trust-badge"><span class="trust-badge-icon">✅</span>Free Cancellation (24h)</div>
                <div class="trust-badge"><span class="trust-badge-icon">📞</span>24/7 Customer Support</div>
            </div>

            <div class="btn-confirm-wrap">
                <button class="btn-confirm" id="confirmBtn" onclick="submitBooking()">
                    <span class="btn-text">Confirm Booking →</span>
                    <div class="btn-spinner"></div>
                </button>
            </div>
        </div>
    </div>

</div>

<!-- SUCCESS SCREEN -->
<div id="successScreen">
    <div class="success-circle">✓</div>
    <h1 class="success-title">Booking <em>Confirmed!</em></h1>
    <p class="success-sub" id="successMsg">Your luxury ride has been reserved.</p>
    <div class="success-ref" id="successRef">REF: LXD-2024-XXXX</div>
    <div class="success-btns">
        <a href="home.html" class="btn-gold">Back to Fleet</a>
        <a href="#" class="btn-outline" onclick="window.print(); return false;">Print Confirmation</a>
    </div>
</div>

<script>
    /* ── DATA ── */
    const CARS = {
        'bmw-m5':        { name: 'BMW M5',             type: 'Luxury',   price: 10000, img: 'https://images.unsplash.com/photo-1555215695-3004980ad54e?w=800&q=80' },
        'audi-r8':       { name: 'Audi R8',             type: 'Sports',   price: 20000, img: 'https://images.unsplash.com/photo-1603584173870-7f23fdae1b7a?w=800&q=80' },
        'range-rover':   { name: 'Range Rover Velar',   type: 'SUV',      price: 15000, img: 'https://images.unsplash.com/photo-1519641471654-76ce0107ad1b?w=800&q=80' },
        'mercedes-s':    { name: 'Mercedes S-Class',    type: 'Luxury',   price: 12000, img: 'https://images.unsplash.com/photo-1618843479313-40f8afb4b4d8?w=800&q=80' },
        'tesla-model-s': { name: 'Tesla Model S',       type: 'Electric', price: 13000, img: 'https://images.unsplash.com/photo-1561580125-028ee3bd62eb?w=800&q=80' },
        'lambo-huracan': { name: 'Lamborghini Huracán', type: 'Sports',   price: 30000, img: 'https://images.unsplash.com/photo-1511919884226-fd3cad34687c?w=800&q=80' },
    };

    let currentId  = 'bmw-m5';
    let currentCar = CARS[currentId];

    /* ── HELPERS ── */
    function fmt(n) {
        return '₹' + Number(n).toLocaleString('en-IN');
    }

    function bumpTotal() {
        const el = document.getElementById('sumTotal');
        el.classList.remove('bump');
        void el.offsetWidth;          // reflow to restart animation
        el.classList.add('bump');
    }

    /* ── CAR SELECTOR PILLS ── */
    function buildPills() {
        const bar = document.getElementById('carSelectorBar');
        bar.innerHTML = '';
        Object.keys(CARS).forEach(id => {
            const btn = document.createElement('button');
            btn.className = 'car-pill' + (id === currentId ? ' active' : '');
            btn.textContent = CARS[id].name;
            btn.onclick = () => selectCar(id);
            bar.appendChild(btn);
        });
    }

    function selectCar(id) {
        currentId  = id;
        currentCar = CARS[id];

        /* update pills */
        document.querySelectorAll('.car-pill').forEach(p => {
            p.classList.toggle('active', p.textContent === currentCar.name);
        });

        /* update breadcrumb */
        document.getElementById('breadCar').textContent = currentCar.name;

        /* update summary card */
        document.getElementById('summaryImg').src          = currentCar.img;
        document.getElementById('summaryImg').alt          = currentCar.name;
        document.getElementById('summaryName').textContent = currentCar.name;
        document.getElementById('summaryType').textContent = currentCar.type;

        updateSummary();
    }

    /* ── DAYS ── */
    function changeDays(delta) {
        const inp = document.getElementById('daysInput');
        let val = (parseInt(inp.value) || 1) + delta;
        val = Math.min(30, Math.max(1, val));
        inp.value = val;
        updateDates();
    }

    /* ── DATES ── */
    function updateDates() {
        const pickupVal = document.getElementById('pickupDate').value;
        const days      = parseInt(document.getElementById('daysInput').value) || 1;

        if (pickupVal) {
            const [y, m, d] = pickupVal.split('-').map(Number);
            const pickup    = new Date(y, m - 1, d);
            const ret       = new Date(y, m - 1, d + days);
            const opts      = { day: 'numeric', month: 'short', year: 'numeric' };
            document.getElementById('pickupDisplay').textContent = pickup.toLocaleDateString('en-IN', opts);
            document.getElementById('returnDisplay').textContent = ret.toLocaleDateString('en-IN', opts);
        } else {
            document.getElementById('pickupDisplay').textContent = '—';
            document.getElementById('returnDisplay').textContent = '—';
        }
        updateSummary();
    }

    /* ── SUMMARY ── */
    function updateSummary() {
        if (!currentCar) return;
        const days        = parseInt(document.getElementById('daysInput').value) || 1;
        const driverExtra = parseInt(document.getElementById('driverOpt').value) || 0;
        const insExtra    = parseInt(document.getElementById('insOpt').value)    || 0;
        const total       = (currentCar.price + driverExtra + insExtra) * days;

        document.getElementById('sumDays').textContent   = days;
        document.getElementById('sumPPD').textContent    = fmt(currentCar.price);
        document.getElementById('sumDriver').textContent = driverExtra ? fmt(driverExtra) + '/day' : 'Free';
        document.getElementById('sumIns').textContent    = insExtra    ? fmt(insExtra)    + '/day' : 'Included';
        document.getElementById('sumTotal').textContent  = fmt(total);
        bumpTotal();
    }

    /* ── VALIDATION ── */
    function validate() {
        const fields = [
            { id: 'firstName',  err: 'errFirstName', check: v => v.trim().length > 0 },
            { id: 'lastName',   err: 'errLastName',  check: v => v.trim().length > 0 },
            { id: 'email',      err: 'errEmail',     check: v => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim()) },
            { id: 'phone',      err: 'errPhone',     check: v => v.trim().length > 0 },
            { id: 'pickupDate', err: 'errPickup',    check: v => v !== '' },
        ];
        let ok = true;
        fields.forEach(f => {
            const inp = document.getElementById(f.id);
            const err = document.getElementById(f.err);
            const pass = f.check(inp.value);
            inp.classList.toggle('error', !pass);
            err.classList.toggle('show',  !pass);
            if (!pass) ok = false;
        });
        return ok;
    }

    /* ── SUBMIT ── */
    function submitBooking() {
        if (!validate()) return;

        const btn = document.getElementById('confirmBtn');
        btn.classList.add('loading');
        btn.disabled = true;

        document.getElementById('step3').classList.add('active');
        document.getElementById('line2').classList.add('done');

        setTimeout(() => {
            btn.classList.remove('loading');
            const ref  = 'LXD-' + new Date().getFullYear() + '-' + Math.floor(1000 + Math.random() * 9000);
            const name = document.getElementById('firstName').value.trim();
            const mail = document.getElementById('email').value.trim();

            document.getElementById('successRef').textContent =
                'Reference: ' + ref;
            document.getElementById('successMsg').textContent =
                `Thank you, ${name}! Your ${currentCar.name} has been reserved. A confirmation has been sent to ${mail}.`;

            document.getElementById('successScreen').classList.add('show');
        }, 2000);
    }

    /* ── INIT ── */
    function init() {
        /* Try to read car id from URL: ?id=audi-r8 */
        const params = new URLSearchParams(window.location.search);
        const urlId  = params.get('id');
        if (urlId && CARS[urlId]) {
            currentId  = urlId;
            currentCar = CARS[urlId];
        }

        buildPills();
        selectCar(currentId);   /* populates summary card */

        /* Set min date = today (local) */
        const now   = new Date();
        const today = now.getFullYear() + '-'
                    + String(now.getMonth() + 1).padStart(2, '0') + '-'
                    + String(now.getDate()).padStart(2, '0');
        const dp = document.getElementById('pickupDate');
        dp.min   = today;
        dp.value = today;

        updateDates();
    }

    document.addEventListener('DOMContentLoaded', init);
</script>
</body>
</html>

