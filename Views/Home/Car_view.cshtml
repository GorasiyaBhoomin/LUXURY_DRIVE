@{
    Layout = null;

    ViewData["Title"] = "Car_view";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car Details – LUXE DRIVE</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/carview.css" asp-append-version="true" />

</head>
<body class="page-enter">

    <div class="page-transition" id="pageTransition"></div>

    <!-- NAV -->
    <nav>
        <a href="Home/Index" class="nav-logo" onclick="goToPage('Index', event)">
            <div>
                <div class="brand">LUXE DRIVE</div>
                <div class="sub">Premium Rentals</div>
            </div>
        </a>
        <a href="Home/Index" class="nav-back" onclick="goToPage('Index', event)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6" /></svg>
            Back to Fleet
        </a>
    </nav>

    <!-- BREADCRUMB -->
    <div class="breadcrumb">
        <a href="Home/Index" onclick="goToPage('Index', event)">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>

        <span id="breadCar">Loading...</span>
    </div>

    <!-- MAIN DETAIL -->
    <div class="car-detail-wrap">

        <!-- LEFT: GALLERY -->
        <div class="car-gallery">
            <div class="main-img-wrap">
                <img class="main-img" id="mainImg" src="" alt="">
                <div class="main-img-overlay"></div>
                <div class="car-type-ribbon" id="typeRibbon">—</div>
            </div>
            <div class="thumb-row" id="thumbRow"></div>
            <div class="stats-bar" id="statsBar">
                <div class="stat-item"><div class="stat-icon">⚡</div><span class="stat-val" id="stat0">—</span><span class="stat-lbl">0–100 km/h</span></div>
                <div class="stat-item"><div class="stat-icon">🔝</div><span class="stat-val" id="stat1">—</span><span class="stat-lbl">Top Speed</span></div>
                <div class="stat-item"><div class="stat-icon">🐎</div><span class="stat-val" id="stat2">—</span><span class="stat-lbl">Horsepower</span></div>
                <div class="stat-item"><div class="stat-icon">⛽</div><span class="stat-val" id="stat3">—</span><span class="stat-lbl">Mileage</span></div>
            </div>
        </div>

        <!-- RIGHT: DETAILS -->
        <div class="car-details-col">
            <div class="car-eyebrow" id="carEyebrow">Premium Fleet</div>
            <h1 class="car-title" id="carTitle">Loading...</h1>
            <div class="car-subtitle" id="carSubtitle">—</div>

            <div class="price-block">
                <div class="price-main" id="carPrice">—</div>
                <div class="price-period">/ day</div>
                <div class="price-note">Inclusive of taxes</div>
            </div>

            <div class="specs-title">Specifications</div>
            <div class="specs-table" id="specsTable"></div>

            <div class="desc-block">
                <div class="specs-title">About This Car</div>
                <p class="desc-text" id="carDesc">—</p>
            </div>

            <div class="specs-title">Key Features</div>
            <div class="features-grid" id="featuresGrid"></div>

            <div class="cta-area">
                <a href="/Home/Car_rent" class="btn-gold-lg" id="rentBtn" onclick="goToBooking(event)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                    Rent Now
                </a>
                <a href="Home/Index" class="btn-outline-lg" onclick="goToPage('Index', event)">← Back</a>
            </div>
        </div>
    </div>

   

    <script>
        // CAR DATA
        const CARS = {
            'bmw-m5': {
