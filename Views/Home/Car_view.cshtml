@{
    Layout = null;

    ViewData["Title"] = "Car_view";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Car Details – LUXE DRIVE</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Montserrat:wght@300;400;500;600;700&family=Bebas+Neue&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/carview.css" asp-append-version="true" />

</head>
<body class="page-enter">

    <div class="page-transition" id="pageTransition"></div>

    <!-- NAV -->
    <nav>
        <a href="Home/Index" class="nav-logo" onclick="goToPage('Index', event)">
            <div>
                <div class="brand">LUXE DRIVE</div>
                <div class="sub">Premium Rentals</div>
            </div>
        </a>
        <a href="Home/Index" class="nav-back" onclick="goToPage('Index', event)">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6" /></svg>
            Back to Fleet
        </a>
    </nav>

    <!-- BREADCRUMB -->
    <div class="breadcrumb">
        <a href="Home/Index" onclick="goToPage('Index', event)">Home</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6" /></svg>

        <span id="breadCar">Loading...</span>
    </div>

    <!-- MAIN DETAIL -->
    <div class="car-detail-wrap">

        <!-- LEFT: GALLERY -->
        <div class="car-gallery">
            <div class="main-img-wrap">
                <img class="main-img" id="mainImg" src="" alt="">
                <div class="main-img-overlay"></div>
                <div class="car-type-ribbon" id="typeRibbon">—</div>
            </div>

            <div class="stats-bar" id="statsBar">
                <div class="stat-item"><div class="stat-icon">⚡</div><span class="stat-val" id="stat0">—</span><span class="stat-lbl">0–100 km/h</span></div>
                <div class="stat-item"><div class="stat-icon">🔝</div><span class="stat-val" id="stat1">—</span><span class="stat-lbl">Top Speed</span></div>
                <div class="stat-item"><div class="stat-icon">🐎</div><span class="stat-val" id="stat2">—</span><span class="stat-lbl">Horsepower</span></div>
                <div class="stat-item"><div class="stat-icon">⛽</div><span class="stat-val" id="stat3">—</span><span class="stat-lbl">Mileage</span></div>
            </div>
        </div>

        <!-- RIGHT: DETAILS -->
        <div class="car-details-col">
            <div class="car-eyebrow" id="carEyebrow">Premium Fleet</div>
            <h1 class="car-title" id="carTitle">Loading...</h1>
            <div class="car-subtitle" id="carSubtitle">—</div>

            <div class="price-block">
                <div class="price-main" id="carPrice">—</div>
                <div class="price-period">/ day</div>
                <div class="price-note">Inclusive of taxes</div>
            </div>

            <div class="specs-title">Specifications</div>
            <div class="specs-table" id="specsTable"></div>

            <div class="desc-block">
                <div class="specs-title">About This Car</div>
                <p class="desc-text" id="carDesc">—</p>
            </div>

            <div class="specs-title">Key Features</div>
            <div class="features-grid" id="featuresGrid"></div>

            <div class="cta-area">
                <a href="/Home/Car_rent" class="btn-gold-lg" id="rentBtn" onclick="goToBooking(event)">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
                    Rent Now
                </a>
                <a href="Home/Index" class="btn-outline-lg" onclick="goToPage('Index', event)">← Back</a>
            </div>
        </div>
    </div>

   

    <script>
        // CAR DATA
        // CAR DATA
        const CARS = {
        @foreach(var car in ViewBag.Vehicles) {
            <text>
            '@car.VehicleId': {
                name: '@Html.Raw(car.Name?.Replace("'", "\\'"))', type: '@Html.Raw(car.Category?.Replace("'", "\\'"))', subtitle: '@Html.Raw(car.SubTitle?.Replace("'", "\\'"))',
                price: '₹@car.PriceDay', priceNum: @car.PriceDay,
                img: '@Html.Raw(car.ImageUrl)',
                thumbs: [
                    '@Html.Raw(car.ImageUrl)',
                    '@Html.Raw(car.ImageUrl)',
                    '@Html.Raw(car.ImageUrl)'
                ],
                stats: ['@Html.Raw(car.Acc)','@Html.Raw(car.TopSpeed)','@Html.Raw(car.Horsepower)','@Html.Raw(car.Mileage)'],
                specs: [
                    {icon:'🚗', key:'Type', val:'@Html.Raw(car.Category?.Replace("'", "\\'"))'},
                    {icon:'👥', key:'Seats', val:'@Html.Raw(car.Seats?.Replace("'", "\\'") ?? "4 Passengers")'},
                    {icon:'⚙️', key:'Transmission', val:'@Html.Raw(car.Transmission?.Replace("'", "\\'") ?? "Automatic")'},
                    {icon:'⛽', key:'Fuel', val:'@Html.Raw(car.Fuel?.Replace("'", "\\'") ?? "Petrol")'},
                    {icon:'📅', key:'Year', val:'@Html.Raw(car.Year?.Replace("'", "\\'") ?? "2024")'},
                    {icon:'🎨', key:'Color', val:'@Html.Raw(car.Color?.Replace("'", "\\'") ?? "Standard")'}
                ],
                features: '@Html.Raw(car.KeyFeatures?.Replace("'", "\\'") ?? "")' 
                          ? '@Html.Raw(car.KeyFeatures?.Replace("'", "\\'") ?? "")'.split(',').map(s => s.trim()).filter(Boolean) 
                          : ['Premium Audio', 'Leather Seats', 'Rear Camera', 'Cruise Control'],
                desc: `@Html.Raw(car.Description?.Replace("`", "\\`")?.Replace("\n", " ")?.Replace("\r", ""))`
            },
            </text>
        }
        };

        const SIMILAR_MAP = {};
        const allKeys = Object.keys(CARS);
        allKeys.forEach(k => {
             SIMILAR_MAP[k] = allKeys.filter(x => x !== k).slice(0, 3);
        });

        function goToPage(url, e) {
            if (e) e.preventDefault();
            const t = document.getElementById('pageTransition');
            t.classList.add('leaving');
            setTimeout(() => { window.location.href = url; }, 480);
        }

        function goToBooking(e) {
            e.preventDefault();
            goToPage('/Home/Car_rent');
        }

        let currentId = '';
        let currentCar = null;

        function init() {
            const params = new URLSearchParams(window.location.search);
            currentId = params.get('id') || Object.keys(CARS)[0];
            currentCar = CARS[currentId];
            if (!currentCar) { window.location.href = 'home.html'; return; }

            document.title = currentCar.name + ' – LUXE DRIVE';
            document.getElementById('breadCar').textContent = currentCar.name;
            document.getElementById('carEyebrow').textContent = currentCar.type + ' · Premium Fleet';
            document.getElementById('carTitle').textContent = currentCar.name;
            document.getElementById('carSubtitle').textContent = currentCar.subtitle;
            document.getElementById('carPrice').textContent = currentCar.price;
            document.getElementById('typeRibbon').textContent = currentCar.type;
            document.getElementById('carDesc').textContent = currentCar.desc;

            // MAIN IMAGE
            document.getElementById('mainImg').src = currentCar.img;
            document.getElementById('mainImg').alt = currentCar.name;

            // STATS
            currentCar.stats.forEach((s, i) => { document.getElementById('stat' + i).textContent = s; });



            // SPECS
            const specsTable = document.getElementById('specsTable');
            currentCar.specs.forEach((s, i) => {
                const row = document.createElement('div');
                row.className = 'spec-row';
                row.innerHTML = `<div class="spec-key"><div class="spec-key-icon">${s.icon}</div>${s.key}</div><div class="spec-val">${s.val}</div>`;
                row.style.animationDelay = (i * 0.07) + 's';
                specsTable.appendChild(row);
                setTimeout(() => row.classList.add('visible'), 100 + i * 70);
            });

            // FEATURES
            const featGrid = document.getElementById('featuresGrid');
            currentCar.features.forEach(f => {
                const div = document.createElement('div');
                div.className = 'feature-tag';
                div.innerHTML = `<div class="feature-tag-dot"></div>${f}`;
                featGrid.appendChild(div);
            });

            // SIMILAR CARS
            const simIds = SIMILAR_MAP[currentId] || [];
            const simGrid = document.getElementById('similarGrid');
            simIds.forEach(id => {
                const c = CARS[id];
                if (!c) return;
                const div = document.createElement('div');
                div.className = 'sim-card';
                div.innerHTML = `<img src="${c.thumbs[0]}" alt="${c.name}"><div class="sim-info"><div class="sim-name">${c.name}</div><div class="sim-price">${c.price} <span>/day</span></div></div>`;
                div.onclick = () => goToPage('car-view.html?id=' + id);
                simGrid.appendChild(div);
            });
        }

        init();
    </script>
</body>
</html>