    <script>
        // ── HERO SLIDESHOW ──
        let slide = 0;
        const slides = document.querySelectorAll('.hero-slide');
        const dots   = document.querySelectorAll('.hero-dot');

        function goSlide(n) {
          slides[slide].classList.remove('active');
          dots[slide].classList.remove('active');
          slide = n;
          slides[slide].classList.add('active');
          dots[slide].classList.add('active');
        }

        setInterval(() => goSlide((slide + 1) % slides.length), 5000);

        // ── SCROLL REVEAL ──
        const revealEls = document.querySelectorAll('.reveal');
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((e, i) => {
            if (e.isIntersecting) {
              setTimeout(() => e.target.classList.add('visible'), i * 80);
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.12 });
        revealEls.forEach(el => observer.observe(el));

        // ── CAR FILTER ──
        function filterCars() {
          const query = document.getElementById('searchInput').value.toLowerCase();
          const type  = document.getElementById('typeFilter').value;
          document.querySelectorAll('.car-card').forEach(card => {
            const name = card.dataset.name.toLowerCase();
            const t    = card.dataset.type;
            const show = name.includes(query) && (!type || t === type);
            card.style.display = show ? '' : 'none';
          });
        }

        // ── FORM SUBMIT ──
        function submitForm() {
          const btn = event.target;
          btn.textContent = '✓ Message Sent!';
          btn.style.background = '#16a34a';
          setTimeout(() => { btn.textContent = 'Send Message'; btn.style.background = ''; }, 3000);
        }

        // ── STICKY NAV SHADOW ──
        window.addEventListener('scroll', () => {
          document.querySelector('nav').style.boxShadow =
            window.scrollY > 60 ? '0 4px 30px rgba(0,0,0,0.6)' : 'none';
        });

        // ── AUTO SCROLL ON VALIDATION ERROR ──
        @if (ViewBag.ShowContactError == true) {
            <text>
            document.addEventListener("DOMContentLoaded", function () {
                document.getElementById('contact').scrollIntoView({ behavior: 'smooth' });
            });
            </text>
        }
    </script>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const form = document.querySelector('.contact-form');
            if (!form) return;
            if (window.$ && $.validator && $.validator.unobtrusive) {
                $.validator.unobtrusive.parse(form);
            }
            form.addEventListener('submit', function (e) {
                if (window.$ && $(form).length && !$(form).valid()) {
                    e.preventDefault();
                }
            });
        });
    </script>

</body>
