@{
    Layout = null;
    ViewData["Title"] = "Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile – LUXE DRIVE</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
</head>
<body>

    <!-- NAVBAR -->
    <nav>
        <a asp-controller="Home" asp-action="Index" class="nav-logo">
            <div class="nav-logo-icon">🛡</div>
            <div class="nav-logo-text">
                <div class="brand">LUXE DRIVE</div>
                <div class="sub">Premium Rentals</div>
            </div>
        </a>
        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a href="#cars">Cars</a>
            <a href="#why">About</a>
            <a href="#contact">Contact</a>
            <div class="nav-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </div>
        </div>
    </nav>

    <!-- PROFILE PAGE -->
    <div class="profile-page">

        <h1 class="page-title">My Profile</h1>

        <div class="profile-layout">

            <!-- SIDEBAR -->
            <aside class="profile-sidebar">
                <div class="avatar-wrap">
                    <div class="avatar-circle">G</div>
                </div>
                <div class="sidebar-name">User</div>
                <div class="sidebar-email">user@gmail.com</div>
                <div class="sidebar-logo">
                    <div class="sidebar-logo-icon">🛡</div>
                    <div>
                        <div class="sidebar-logo-brand">LUXE DRIVE</div>
                        <div class="sidebar-logo-sub">Premium Rentals</div>
                    </div>
                </div>
               
            </aside>

            <!-- MAIN CONTENT -->
            <div class="profile-content">

                <!-- TABS -->
                <div class="tab-bar">
                    <button class="tab active" onclick="switchTab('personal')">Personal Details</button>
                    <button class="tab" onclick="switchTab('password')">Password</button>
                    <button class="tab" onclick="switchTab('statistics')">Statistics</button>
                    <button class="tab" onclick="switchTab('actions')">Account Actions</button>
                </div>

@{ string activeTab = (string)ViewBag.ActiveTab; }
                <!-- PERSONAL DETAILS -->
                <div class="tab-panel @(activeTab == "personal" || activeTab == null ? "active" : "")" id="panel-personal">
                    <form asp-controller="Home" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="panel-title">Personal Information</div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Full Name</label>
                                <input type="text" name="FullName" class="form-input"
                                       data-val="true" data-val-required="Full Name is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="FullName" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" name="Username" class="form-input"
                                       data-val="true" data-val-required="Username is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="Username" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" name="Email" class="form-input"
                                       data-val="true" data-val-required="Email is required."
                                       data-val-email="Invalid email format.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="Email" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Phone</label>
                                <input type="tel" name="PhoneNumber" class="form-input"
                                       data-val="true" data-val-required="Phone Number is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="PhoneNumber" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn-gold">Save Changes</button>
                            <button type="reset" class="btn-outline-gold">Reset</button>
                        </div>
                    </form>
                </div>

                <!-- PASSWORD TAB -->
                <div class="tab-panel @(activeTab == "password" ? "active" : "")" id="panel-password">
                    <form asp-controller="Home" asp-action="UpdatePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="panel-title">Change Password</div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Current Password</label>
                                <input type="password" name="CurrentPassword" class="form-input"
                                       data-val="true" data-val-required="Current password is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="CurrentPassword" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>New Password</label>
                                <input type="password" name="NewPassword" class="form-input"
                                       data-val="true" data-val-required="New password is required."
                                       data-val-length="Password must be at least 6 characters." data-val-length-min="6" data-val-length-max="100">
                                <span class="field-validation-valid text-danger" data-valmsg-for="NewPassword" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Confirm Password</label>
                                <input type="password" name="ConfirmPassword" class="form-input"
                                       data-val="true" data-val-required="Please confirm your new password."
                                       data-val-equalto="Passwords do not match." data-val-equalto-other="*.NewPassword">
                                <span class="field-validation-valid text-danger" data-valmsg-for="ConfirmPassword" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn-gold">Update Password</button>
                        </div>
                    </form>
                </div>

                <!-- STATISTICS -->
                <div class="tab-panel" id="panel-statistics">
                    <div class="panel-title">Account Statistics</div>
                    <p>No statistics available.</p>
                </div>

                <!-- ACCOUNT ACTIONS -->
                <div class="tab-panel" id="panel-actions">
                    <div class="panel-title">Account Actions</div>
                    <button class="btn-gold" onclick="logOut()">Log Out</button>
                </div>

            </div>

        </div>

    </div>

    <script>
        function switchTab(tab) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.sidebar-nav-item').forEach(a => a.classList.remove('active'));
            document.getElementById('panel-' + tab).classList.add('active');
            event.currentTarget.classList.add('active');
        }

        function logOut() {
            window.location.href = "/Authentication/Login";
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('form').forEach(function (form) {
                if (window.$ && $.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse(form);
                }
                form.addEventListener('submit', function (e) {
                    if (window.$ && $(form).length && !$(form).valid()) {
                        e.preventDefault();
                    }
                });
            });
        });
    </script>

</body>
</html>
