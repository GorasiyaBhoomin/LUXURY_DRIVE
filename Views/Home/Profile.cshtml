@{
    // Layout = null;

    ViewData["Title"] = "Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile – LUXE DRIVE</title>

    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
</head>
<body>

    <!-- NAVBAR -->
    <nav>

        <!-- FIXED LINK -->
        <a asp-controller="Home" asp-action="Index" class="nav-logo">
            <div class="nav-logo-icon">🛡</div>

            <div class="nav-logo-text">
                <div class="brand">LUXE DRIVE</div>
                <div class="sub">Premium Rentals</div>
            </div>
        </a>

        <div class="nav-links">

            <!-- FIXED LINK -->
            <a asp-controller="Home" asp-action="Index">Home</a>

            <a href="#cars">Cars</a>
            <a href="#why">About</a>
            <a href="#contact">Contact</a>
            <!-- PROFILE ICON -->
            <div class="nav-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor"
                     stroke-width="1.8"
                     stroke-linecap="round"
                     stroke-linejoin="round">

                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />

                </svg>
            </div>

        </div>
    </nav>


    <!-- PROFILE PAGE -->
    <div class="profile-page">

        <h1 class="page-title">My Profile</h1>

        <div class="profile-layout">

            <!-- SIDEBAR -->
            <aside class="profile-sidebar">

                <div class="avatar-wrap">
                    <div class="avatar-circle">G</div>
                </div>

                <div class="sidebar-name">User</div>
                <div class="sidebar-email">user@gmail.com</div>

                <nav class="sidebar-nav">

                    <a class="sidebar-nav-item active" onclick="switchTab('personal')" href="#">
                        👤 Personal Details
                    </a>

                    <a class="sidebar-nav-item" onclick="switchTab('password')" href="#">
                        🔒 Password
                    </a>

                    <a class="sidebar-nav-item" onclick="switchTab('statistics')" href="#">
                        📊 Statistics
                    </a>

                    <a class="sidebar-nav-item" onclick="switchTab('actions')" href="#">
                        ⚙️ Account Actions
                    </a>

                </nav>

            </aside>


            <!-- MAIN CONTENT -->
            <div class="profile-content">

                <!-- TABS -->
                <div class="tab-bar">

                    <button class="tab active" onclick="switchTab('personal')">
                        Personal Details
                    </button>

                    <button class="tab" onclick="switchTab('password')">
                        Password
                    </button>

                    <button class="tab" onclick="switchTab('statistics')">
                        Statistics
                    </button>

                    <button class="tab" onclick="switchTab('actions')">
                        Account Actions
                    </button>

                </div>


                <!-- PERSONAL DETAILS -->
                <div class="tab-panel active" id="panel-personal">

                    <div class="panel-title">
                        Personal Information
                    </div>

                    <div class="form-grid">

                        <div class="form-group">
                            <label>Full Name</label>
                            <input type="text" class="form-input">
                        </div>

                        <div class="form-group">
                            <label>Username</label>
                            <input type="text" class="form-input">
                        </div>

                        <div class="form-group">
                            <label>Email</label>
                            <input type="email" class="form-input">
                        </div>

                        <div class="form-group">
                            <label>Phone</label>
                            <input type="tel" class="form-input">
                        </div>

                    </div>

                    <div class="form-actions">

                        <button class="btn-gold">
                            Save Changes
                        </button>

                        <button class="btn-outline-gold">
                            Reset
                        </button>

                    </div>

                </div>


                <!-- PASSWORD TAB -->
                <div class="tab-panel" id="panel-password">

                    <div class="panel-title">
                        Change Password
                    </div>

                    <div class="form-grid">

                        <div class="form-group">
                            <label>Current Password</label>
                            <input type="password" class="form-input">
                        </div>

                        <div class="form-group">
                            <label>New Password</label>
                            <input type="password" class="form-input">
                        </div>

                        <div class="form-group">
                            <label>Confirm Password</label>
                            <input type="password" class="form-input">
                        </div>

                    </div>

                    <div class="form-actions">
                        <button class="btn-gold">
                            Update Password
                        </button>
                    </div>

                </div>


                <!-- STATISTICS -->
                <div class="tab-panel" id="panel-statistics">

                    <div class="panel-title">
                        Account Statistics
                    </div>

                    <p>No statistics available.</p>

                </div>


                <!-- ACCOUNT ACTIONS -->
                <div class="tab-panel" id="panel-actions">

                    <div class="panel-title">
                        Account Actions
                    </div>

                    <button class="btn-gold" onclick="logOut()">
                        Log Out
                    </button>

                </div>

            </div>

        </div>

    </div>


    <script>

        function switchTab(tab) {

            document.querySelectorAll('.tab-panel').forEach(p=>{
                p.classList.remove('active')
            })

            document.getElementById('panel-' + tab).classList.add('active')

        }

        function logOut(){

            window.location.href = "/Authentication/Login"

        }

    </script>

</body>
</html>