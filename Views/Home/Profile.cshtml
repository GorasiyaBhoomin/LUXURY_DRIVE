@model LUXURY_DRIVE.Models.UserProfilePageViewModel
@{
    Layout = null;
    ViewData["Title"] = "Profile";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile – LUXE DRIVE</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600;700&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/profile.css" asp-append-version="true" />
</head>
<body>

    <!-- NAVBAR -->
    <nav>
        <a asp-controller="Home" asp-action="Index" class="nav-logo">
            <div class="nav-logo-icon">🛡</div>
            <div class="nav-logo-text">
                <div class="brand">LUXE DRIVE</div>
                <div class="sub">Premium Rentals</div>
            </div>
        </a>
        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a href="#cars">Cars</a>
            <a href="#why">About</a>
            <a href="#contact">Contact</a>
            <div class="nav-avatar">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="1.8"
                     stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </div>
        </div>
    </nav>

    <!-- PROFILE PAGE -->
    <div class="profile-page">

        <h1 class="page-title">My Profile</h1>

        <div class="profile-layout">

            <!-- SIDEBAR -->
            <aside class="profile-sidebar">
                <div class="avatar-wrap">
                    <div class="avatar-circle">@(Model.Profile?.FullName?.Substring(0, 1).ToUpper() ?? "U")</div>
                </div>
                <div class="sidebar-name">@(Model.Profile?.FullName ?? "User")</div>
                <div class="sidebar-email">@(Model.Profile?.Email ?? "user@example.com")</div>
                <div class="sidebar-logo">
                    <div class="sidebar-logo-icon">🛡</div>
                    <div>
                        <div class="sidebar-logo-brand">LUXE DRIVE</div>
                        <div class="sidebar-logo-sub">Premium Rentals</div>
                    </div>
                </div>
               
            </aside>

            <!-- MAIN CONTENT -->
            <div class="profile-content">

                <!-- TABS -->
                <div class="tab-bar">
                    <button class="tab active" onclick="switchTab('personal')">Personal Details</button>
                    <button class="tab" onclick="switchTab('password')">Password</button>
                    <button class="tab" onclick="switchTab('statistics')">Statistics</button>
                    <button class="tab" onclick="switchTab('actions')">Account Actions</button>
                </div>

@{ string activeTab = (string)ViewBag.ActiveTab; }
                <!-- PERSONAL DETAILS -->
                <div class="tab-panel @(activeTab == "personal" || activeTab == null ? "active" : "")" id="panel-personal">
                    <form asp-controller="Home" asp-action="UpdateProfile" method="post">
                        @Html.AntiForgeryToken()
                        <div class="panel-title">Personal Information</div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Full Name</label>
                                <input type="text" name="FullName" class="form-input" value="@(Model.Profile?.FullName ?? "")"
                                       data-val="true" data-val-required="Full Name is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="FullName" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" name="Username" class="form-input" value="@(Model.Profile?.Username ?? "")"
                                       data-val="true" data-val-required="Username is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="Username" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Email</label>
                                <input type="email" name="Email" class="form-input" value="@(Model.Profile?.Email ?? "")"
                                       data-val="true" data-val-required="Email is required."
                                       data-val-email="Invalid email format.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="Email" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Phone</label>
                                <input type="tel" name="PhoneNumber" class="form-input" value="@(Model.Profile?.PhoneNumber ?? "")"
                                       data-val="true" data-val-required="Phone Number is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="PhoneNumber" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn-gold">Save Changes</button>
                            <button type="reset" class="btn-outline-gold">Reset</button>
                        </div>
                    </form>
                </div>

                <!-- PASSWORD TAB -->
                <div class="tab-panel @(activeTab == "password" ? "active" : "")" id="panel-password">
                    <form asp-controller="Home" asp-action="UpdatePassword" method="post">
                        @Html.AntiForgeryToken()
                        <div class="panel-title">Change Password</div>
                        <div class="form-grid">
                            <div class="form-group">
                                <label>Current Password</label>
                                <input type="password" name="CurrentPassword" class="form-input"
                                       data-val="true" data-val-required="Current password is required.">
                                <span class="field-validation-valid text-danger" data-valmsg-for="CurrentPassword" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>New Password</label>
                                <input type="password" name="NewPassword" class="form-input"
                                       data-val="true" data-val-required="New password is required."
                                       data-val-length="Password must be at least 6 characters." data-val-length-min="6" data-val-length-max="100">
                                <span class="field-validation-valid text-danger" data-valmsg-for="NewPassword" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group">
                                <label>Confirm Password</label>
                                <input type="password" name="ConfirmPassword" class="form-input"
                                       data-val="true" data-val-required="Please confirm your new password."
                                       data-val-equalto="Passwords do not match." data-val-equalto-other="*.NewPassword">
                                <span class="field-validation-valid text-danger" data-valmsg-for="ConfirmPassword" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                        <div class="form-actions">
                            <button type="submit" class="btn-gold">Update Password</button>
                        </div>
                    </form>
                </div>

                <!-- STATISTICS -->
                <div class="tab-panel" id="panel-statistics">
                    <div class="panel-title">Booking History</div>
                    
                    @{
                        var bookings = ViewBag.UserBookings as System.Collections.Generic.List<LUXURY_DRIVE.Models.Entities.CarRent>;
                    }

                    @if (bookings == null || !bookings.Any())
                    {
                        <div style="background-color: #111; padding: 40px; text-align: center; border-radius: 8px; border: 1px solid #333; margin-top: 20px;">
                            <div style="font-size: 30px; margin-bottom: 10px;">🚘</div>
                            <p style="color: #888; font-size: 16px;">You haven't made any bookings yet.</p>
                        </div>
                    }
                    else
                    {
                        <div style="overflow-x: auto; margin-top: 20px;">
                            <table style="width: 100%; border-collapse: collapse; background-color: #111; border-radius: 8px; overflow: hidden; border: 1px solid #222;">
                                <thead>
                                    <tr style="background-color: #080808; color: #c9a84c; text-align: left; font-size: 13px; text-transform: uppercase; letter-spacing: 1px;">
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;">Vehicle</th>
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;">License</th>
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;">Pickup Date</th>
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;">Duration</th>
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;">Amount</th>
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;">Status</th>
                                        <th style="padding: 15px 20px; font-family: 'Montserrat', sans-serif;"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var r in bookings)
                                    {
                                        var amountText = "—";
                                        if (r.Vehicle != null && decimal.TryParse(r.Vehicle.PriceDay?.Replace(",", "").Trim(), out var price))
                                        {
                                            amountText = "₹" + (price * r.NumberOfDays).ToString("N0");
                                        }

                                        var vName = r.Vehicle?.Name ?? "Unknown";
                                        var statusClass = r.Status?.ToLower() == "active" ? "#2db568" : 
                                                          r.Status?.ToLower() == "completed" ? "#3b82f6" : 
                                                          r.Status?.ToLower() == "cancelled" ? "#e05c2e" : "#c9a84c";

                                        <tr style="border-bottom: 1px solid #222; transition: background-color 0.3s;" onmouseover="this.style.backgroundColor='#1a1a1a'" onmouseout="this.style.backgroundColor='transparent'">
                                            <td style="padding: 15px 20px; font-weight: 500; color: #fff;">@vName</td>
                                            <td style="padding: 15px 20px; color: #888;">@r.LicenseNumber</td>
                                            <td style="padding: 15px 20px; color: #888;">@r.PickupDate.ToString("dd MMM yyyy")</td>
                                            <td style="padding: 15px 20px; color: #888;">@r.NumberOfDays d</td>
                                            <td style="padding: 15px 20px; color: #c9a84c; font-weight: 600;">@amountText</td>
                                            <td style="padding: 15px 20px;">
                                                <span style="display: inline-block; padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; background-color: @(statusClass)22; color: @(statusClass); border: 1px solid @(statusClass)44;">
                                                    @(r.Status ?? "PENDING")
                                                </span>
                                            </td>
                                            <td style="padding: 15px 20px; text-align: center;">
                                                <button title="View Details" onclick="openBookingDetail('@vName.Replace("'", "\\'")', '@r.LicenseNumber', '@r.PickupDate.ToString("dd MMM yyyy")', '@r.PickupTime', '@r.NumberOfDays', '@amountText', '@(r.Status ?? "PENDING")')" style="background: none; border: none; color: #888; cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#c9a84c'" onmouseout="this.style.color='#888'">
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                        <circle cx="12" cy="12" r="3" />
                                                    </svg>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <!-- ACCOUNT ACTIONS -->
                <div class="tab-panel" id="panel-actions">
                    <div class="panel-title">Account Actions</div>
                    <button class="btn-gold" onclick="logOut()">Log Out</button>
                </div>

            </div>

        </div>

    </div>

    <!-- BOOKING DETAIL MODAL -->
    <div id="bookingModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
        <div style="background: #111; border: 1px solid #333; border-radius: 12px; width: 400px; max-width: 90%; padding: 30px; position: relative; box-shadow: 0 10px 40px rgba(0,0,0,0.5);">
            <button onclick="document.getElementById('bookingModal').style.display='none'" style="position: absolute; top: 15px; right: 15px; background: none; border: none; color: #888; cursor: pointer; font-size: 28px; line-height: 1;">&times;</button>
            <h2 style="color: #c9a84c; margin-top: 0; margin-bottom: 5px; font-family: 'Cormorant Garamond', serif; font-size: 28px;">Booking Details</h2>
            <div id="bmVehicle" style="color: #fff; font-weight: 600; font-size: 16px; margin-bottom: 20px;"></div>
            
            <div style="display: flex; flex-direction: column; gap: 12px; margin-bottom: 30px;">
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #222; padding-bottom: 8px;">
                    <span style="color: #888; font-size: 13px;">License Plate</span>
                    <span id="bmLicense" style="color: #fff; font-size: 14px; font-weight: 500;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #222; padding-bottom: 8px;">
                    <span style="color: #888; font-size: 13px;">Pickup</span>
                    <span id="bmDate" style="color: #fff; font-size: 14px; font-weight: 500;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #222; padding-bottom: 8px;">
                    <span style="color: #888; font-size: 13px;">Duration</span>
                    <span id="bmDuration" style="color: #fff; font-size: 14px; font-weight: 500;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; border-bottom: 1px solid #222; padding-bottom: 8px;">
                    <span style="color: #888; font-size: 13px;">Total Amount</span>
                    <span id="bmAmount" style="color: #c9a84c; font-size: 15px; font-weight: 600;"></span>
                </div>
                <div style="display: flex; justify-content: space-between; padding-bottom: 8px;">
                    <span style="color: #888; font-size: 13px;">Status</span>
                    <span id="bmStatus" style="color: #fff; font-size: 11px; letter-spacing: 0.5px; font-weight: 700; padding: 3px 10px; border-radius: 20px; background: #222;"></span>
                </div>
            </div>
            
            <button onclick="document.getElementById('bookingModal').style.display='none'" class="btn-gold" style="width: 100%;">Close Panel</button>
        </div>
    </div>

    <script>
        function openBookingDetail(vehicle, license, date, time, duration, amount, status) {
            document.getElementById('bmVehicle').textContent = vehicle;
            document.getElementById('bmLicense').textContent = license;
            document.getElementById('bmDate').textContent = date + ' at ' + time;
            document.getElementById('bmDuration').textContent = duration + ' days';
            document.getElementById('bmAmount').textContent = amount;
            document.getElementById('bmStatus').textContent = status.toUpperCase();
            
            document.getElementById('bookingModal').style.display = 'flex';
        }

        function switchTab(tab) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.sidebar-nav-item').forEach(a => a.classList.remove('active'));
            document.getElementById('panel-' + tab).classList.add('active');
            event.currentTarget.classList.add('active');
        }

        function logOut() {
            window.location.href = "/Authentication/Login";
        }
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            document.querySelectorAll('form').forEach(function (form) {
                if (window.$ && $.validator && $.validator.unobtrusive) {
                    $.validator.unobtrusive.parse(form);
                }
                form.addEventListener('submit', function (e) {
                    if (window.$ && $(form).length && !$(form).valid()) {
                        e.preventDefault();
                    }
                });
            });
        });
    </script>

</body>
</html>
